# Neon Postgres connection strings.
# Provided automatically by the Vercel Neon integration; pull them locally with
# `vercel env pull .env.local --environment=production`.
#
# DATABASE_URL          — pooled connection, used by the app at runtime.
# DATABASE_URL_UNPOOLED — direct connection, used for schema changes / migrations.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:password@direct-host/dbname?sslmode=require
